}

/**
 * Applies formatting to the dashboard sheet
 *
 * @param {Sheet} dashboard - The dashboard sheet to format
 */
function formatDashboard(dashboard) {
  try {
    // Title formatting
    const titleRange = dashboard.getRange(1, 1, 1, 4);
    titleRange.merge();
    titleRange.setFontSize(16).setFontWeight('bold').setBackground('#4285f4').setFontColor('white').setHorizontalAlignment('center');

    // Section headers
    dashboard.getRange(3, 1, 1, 4).setFontWeight('bold').setBackground('#e8f0fe');
    dashboard.getRange(11, 1, 1, 4).setFontWeight('bold').setBackground('#e8f5e8');
    dashboard.getRange(16, 1, 1, 4).setFontWeight('bold').setBackground('#fce8e6');
    dashboard.getRange(21, 1, 1, 4).setFontWeight('bold').setBackground('#fff3e0');

    // Auto-resize columns
    autoResizeJessColumns(dashboard, 1, 4);

    // Freeze header
    freezeJessHeaderRows(dashboard, 1);

    // Apply borders to data sections
    applyStandardBorders(dashboard.getRange(3, 1, 7, 4)); // Working sheets
    applyStandardBorders(dashboard.getRange(11, 1, 4, 4)); // Reference sheets
    applyStandardBorders(dashboard.getRange(16, 1, 4, 4)); // Original data

    // Trim excess
    trimExcessRowsAndColumns(dashboard);

    Logger.log('Dashboard formatting completed');
  } catch (error) {
    Logger.log('Error formatting dashboard: ' + error.toString());
  }
}
