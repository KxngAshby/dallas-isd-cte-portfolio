        'Practicum - Approved Training Plans',
        "=COUNTA('Practicum - Approved Training Plans'!A:A)-1",
        'Ready',
        'Technical programs already approved',
      ],
      [
        'Practicum - Students Without Plans',
        "=COUNTA('Practicum - Students Without Plans'!A:A)-1",
        'Ready',
        'Technical students needing plans',
      ],
      [
        'Career Prep - Training Plans To Approve',
        "=COUNTA('Career Prep - Training Plan To Approve'!A:A)-1",
        'Ready',
        'General prep programs awaiting approval',
      ],
      [
        'Career Prep - Approved Training Plans',
        "=COUNTA('Career Prep - Approved Training Plans'!A:A)-1",
        'Ready',
        'General prep programs already approved',
      ],
      [
        'Career Prep - Students Without Plans',
        "=COUNTA('Career Prep - Students Without Plans'!A:A)-1",
        'Ready',
        'Career prep students needing plans',
      ],
      ['', '', '', ''],
      ['REFERENCE SHEETS', 'Records', 'Status', 'Description'],
      [
        'WBL Classification Summary',
        "=COUNTA('WBL Classification Summary'!A:A)-1",
        'Complete',
        'Detailed breakdown and statistics',
      ],
      ['Campus Contact', "=COUNTA('Campus Contact'!A:A)-1", 'Reference', 'Principal and AP contact information'],
      ['CI Mapping', "=COUNTA('CI Mapping'!A:A)-1", 'Reference', 'Career Institute assignments'],
      ['', '', '', ''],
      ['ORIGINAL DATA (Protected)', 'Records', 'Status', 'Description'],
