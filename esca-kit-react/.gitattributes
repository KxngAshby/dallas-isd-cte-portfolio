# Normalize line endings: store text as LF in the repo, check out native on Windows.
* text=auto

# Explicit text types
*.gs    text
*.js    text
*.html  text
*.json  text
*.md    text

# Binary assets (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.zip   binary
*.pdf   binary
